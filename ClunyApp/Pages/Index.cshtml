@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="row g-3">
    @if (Model != null && Model.Categories != null)
    {
        <div class="row g-3">
            @foreach (var category in Model.Categories)
            {
                <h3 class="mb-2 mt-5">@category.Name</h3>

                @foreach (var product in category.Products)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 product-card">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="card-img-top" style="height:160px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height:160px;">
                                    <div class="text-muted">No image</div>
                                </div>
                            }

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mb-1">@product.Name</h5>
                                <p class="card-text text-muted mb-2" style="min-height:2.5rem;overflow:hidden;">@product.Description</p>

                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="fw-bold">@product.Price.ToString("C")</div>
                                        <div class="text-muted small">@product.Category?.Name</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

           
        </div>
    } else
    {
        <div class="col-12">
            <div class="alert alert-info my-4">
                No products available at the moment.
            </div>
        </div>
    }
</div>